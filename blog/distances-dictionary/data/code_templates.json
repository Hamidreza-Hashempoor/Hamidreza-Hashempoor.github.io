  "euclidean": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["For large arrays np.linalg.norm is fastest."],
    "numpy": [
      "import numpy as np",
      "",
      "def euclidean(p, q):",
      "    p = np.asarray(p, dtype=float)",
      "    q = np.asarray(q, dtype=float)",
      "    return float(np.linalg.norm(p - q))",
      "",
      "print(euclidean([0, 0], [3, 4]))  # 5.0"
    ],
    "pytorch": [
      "import torch",
      "",
      "def euclidean(p, q):",
      "    return torch.linalg.norm(p - q)"
    ],
    "jax": [
      "import jax.numpy as jnp",
      "",
      "def euclidean(p, q):",
      "    return jnp.linalg.norm(p - q)"
    ]
  },
