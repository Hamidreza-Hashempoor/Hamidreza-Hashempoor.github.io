  "generalized_kl": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["For nonnegative (possibly unnormalized) vectors."],
    "numpy": [
      "import numpy as np",
      "",
      "def generalized_kl(x, y, eps=1e-12):",
      "    x = np.asarray(x, float); y = np.asarray(y, float)",
      "    xc = np.clip(x, eps, None); yc = np.clip(y, eps, None)",
      "    return float(np.sum(xc * np.log(xc / yc) - x + y))"
    ]
  },
  "itakura_saito": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["Scale-invariant: IS(c*p || c*q) == IS(p || q). Inputs must be positive."],
    "numpy": [
      "import numpy as np",
      "",
      "def itakura_saito(p, q, eps=1e-12):",
      "    p = np.clip(np.asarray(p, float), eps, None)",
      "    q = np.clip(np.asarray(q, float), eps, None)",
      "    r = p / q",
      "    return float(np.sum(r - np.log(r) - 1.0))",
      "",
      "print(itakura_saito([1, 2, 3], [1, 1, 4]))  # ~0.345"
    ]
  },
  "logdet_bregman": {
    "requires_probability": false,
    "requires_spd": true,
    "notes": ["Use solve, not an explicit inverse.", "slogdet sign check guards against non-SPD inputs."],
    "numpy": [
      "import numpy as np",
      "",
      "def logdet_bregman(P, Q):",
      "    '''D(P||Q) = tr(P Q^-1) - log det(P Q^-1) - n; P, Q SPD.'''",
      "    P = np.asarray(P, dtype=float); Q = np.asarray(Q, dtype=float)",
      "    n = P.shape[0]",
      "    X = np.linalg.solve(Q, P)            # Q^-1 P",
      "    sign, logdet = np.linalg.slogdet(X)",
      "    if sign <= 0:",
      "        raise ValueError('P Q^-1 must have positive determinant; check SPD inputs.')",
      "    return float(np.trace(X) - logdet - n)",
      "",
      "print(logdet_bregman([[2, 0], [0, 1]], [[1, 0], [0, 1]]))  # ~0.307"
    ],
    "pytorch": [
      "import torch",
      "",
      "def logdet_bregman(P, Q):",
      "    n = P.shape[0]",
      "    X = torch.linalg.solve(Q, P)",
      "    sign, logabsdet = torch.linalg.slogdet(X)",
      "    if sign <= 0:",
      "        raise ValueError('P Q^-1 must have positive determinant; check SPD inputs.')",
      "    return torch.trace(X) - logabsdet - n"
    ],
    "jax": [
      "import jax.numpy as jnp",
      "",
      "def logdet_bregman(P, Q):",
      "    n = P.shape[0]",
      "    X = jnp.linalg.solve(Q, P)",
      "    sign, logdet = jnp.linalg.slogdet(X)",
      "    return jnp.trace(X) - logdet - n"
    ]
  },
  "frobenius": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["Squared version is the Frobenius matrix Bregman divergence."],
    "numpy": [
      "import numpy as np",
      "",
      "def frobenius(X, Y):",
      "    return float(np.linalg.norm(np.asarray(X, float) - np.asarray(Y, float), 'fro'))",
      "",
      "print(frobenius([[2, 0], [0, 1]], [[1, 0], [0, 1]]))  # 1.0"
    ],
    "pytorch": [
      "import torch",
      "",
      "def frobenius(X, Y):",
      "    return torch.linalg.norm(X - Y, ord='fro')"
    ]
  },
  "von_neumann_divergence": {
    "requires_probability": false,
    "requires_spd": true,
    "notes": ["Matrix log via eigendecomposition; inputs must be SPD."],
    "numpy": [
      "import numpy as np",
      "",
      "def _logm(M, eps=1e-12):",
      "    w, V = np.linalg.eigh(M)",
      "    w = np.clip(w, eps, None)",
      "    return (V * np.log(w)) @ V.T",
      "",
      "def von_neumann_divergence(P, Q):",
      "    P = np.asarray(P, float); Q = np.asarray(Q, float)",
      "    return float(np.trace(P @ (_logm(P) - _logm(Q)) - P + Q))",
      "",
      "print(von_neumann_divergence([[0.7, 0], [0, 0.3]], [[0.5, 0], [0, 0.5]]))  # ~0.082"
    ]
  },
  "bhattacharyya": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["BC = sum sqrt(p*q); distance = -log(BC)."],
    "numpy": [
      "import numpy as np",
      "",
      "def bhattacharyya(p, q):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    q = np.asarray(q, float); q = q / q.sum()",
      "    bc = np.sum(np.sqrt(p * q))",
      "    return float(-np.log(bc))",
      "",
      "print(bhattacharyya([0.5, 0.5], [0.9, 0.1]))  # ~0.112"
    ]
  },
  "chernoff": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["Grid-search alpha in (0, 1)."],
    "numpy": [
      "import numpy as np",
      "",
      "def chernoff(p, q, grid=None):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    q = np.asarray(q, float); q = q / q.sum()",
      "    if grid is None:",
      "        grid = np.linspace(0.01, 0.99, 99)",
      "    vals = [-np.log(np.sum(p ** a * q ** (1 - a))) for a in grid]",
      "    return float(np.max(vals))",
      "",
      "print(chernoff([0.5, 0.5], [0.9, 0.1]))  # ~0.112"
    ]
  },
  "renyi_divergence": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["At alpha=1 this returns the KL limit."],
    "numpy": [
      "import numpy as np",
      "",
      "def renyi_divergence(p, q, alpha=0.5, eps=1e-12):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    q = np.asarray(q, float); q = q / q.sum()",
      "    p = np.clip(p, eps, 1.0); q = np.clip(q, eps, 1.0)",
      "    if abs(alpha - 1.0) < 1e-8:",
      "        return float(np.sum(p * np.log(p / q)))",
      "    return float(1.0 / (alpha - 1.0) * np.log(np.sum(p ** alpha * q ** (1 - alpha))))",
      "",
      "print(renyi_divergence([0.5, 0.5], [0.9, 0.1], alpha=0.5))  # ~0.223"
    ]
  },
  "jeffreys": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["Symmetric but unbounded."],
    "numpy": [
      "import numpy as np",
      "",
      "def jeffreys(p, q, eps=1e-12):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    q = np.asarray(q, float); q = q / q.sum()",
      "    p = np.clip(p, eps, 1.0); q = np.clip(q, eps, 1.0)",
      "    return float(np.sum(p * np.log(p / q)) + np.sum(q * np.log(q / p)))",
      "",
      "print(jeffreys([0.5, 0.5], [0.9, 0.1]))  # ~0.879"
    ],
    "pytorch": [
      "import torch",
      "",
      "def jeffreys(p, q, eps=1e-12):",
      "    p = (p / p.sum()).clamp_min(eps)",
      "    q = (q / q.sum()).clamp_min(eps)",
      "    return torch.sum(p * torch.log(p / q)) + torch.sum(q * torch.log(q / p))"
    ]
  },
  "jensen_shannon": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["Always finite (bounded by log 2); sqrt(JS) is a metric."],
    "numpy": [
      "import numpy as np",
      "",
      "def _kl(p, q, eps=1e-12):",
      "    p = np.clip(p, eps, 1.0); q = np.clip(q, eps, 1.0)",
      "    return np.sum(p * np.log(p / q))",
      "",
      "def js_divergence(p, q, eps=1e-12):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    q = np.asarray(q, float); q = q / q.sum()",
      "    m = 0.5 * (p + q)",
      "    return float(0.5 * _kl(p, m, eps) + 0.5 * _kl(q, m, eps))",
      "",
      "print(js_divergence([0.5, 0.5], [0.9, 0.1]))  # ~0.102 nats"
    ],
    "pytorch": [
      "import torch",
      "",
      "def _kl(p, q, eps=1e-12):",
      "    p = p.clamp_min(eps); q = q.clamp_min(eps)",
      "    return torch.sum(p * torch.log(p / q))",
      "",
      "def js_divergence(p, q, eps=1e-12):",
      "    p = p / p.sum(); q = q / q.sum()",
      "    m = 0.5 * (p + q)",
      "    return 0.5 * _kl(p, m, eps) + 0.5 * _kl(q, m, eps)"
    ],
