      "def hellinger(p, q):",
      "    p = p / p.sum(); q = q / q.sum()",
      "    return torch.sqrt(0.5 * torch.sum((torch.sqrt(p) - torch.sqrt(q)) ** 2))"
    ],
    "jax": [
      "import jax.numpy as jnp",
      "",
      "def hellinger(p, q):",
      "    p = p / p.sum(); q = q / q.sum()",
