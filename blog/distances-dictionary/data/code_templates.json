  "bures_wasserstein": {
    "requires_probability": false,
    "requires_spd": true,
    "notes": ["Uses scipy.linalg.sqrtm; clip tiny negatives from round-off."],
    "numpy": [
      "import numpy as np",
      "from scipy.linalg import sqrtm",
      "",
      "def bures_wasserstein(P, Q):",
      "    '''W2 distance between zero-mean Gaussians N(0,P), N(0,Q).'''",
      "    P = np.asarray(P, float); Q = np.asarray(Q, float)",
      "    Ps = sqrtm(P).real",
      "    cross = sqrtm(Ps @ Q @ Ps).real",
      "    d2 = np.trace(P) + np.trace(Q) - 2.0 * np.trace(cross)",
      "    return float(np.sqrt(max(d2, 0.0)))",
      "",
      "print(bures_wasserstein([[4, 0], [0, 1]], [[1, 0], [0, 1]]))  # 1.0"
    ]
  },
