  "affine_invariant_riemannian": {
    "requires_probability": false,
    "requires_spd": true,
    "notes": ["Generalized eigenvalues of (P, Q); both inputs must be SPD."],
    "numpy": [
      "import numpy as np",
      "",
      "def airm(P, Q):",
      "    '''Affine-invariant Riemannian distance between SPD matrices.'''",
      "    P = np.asarray(P, float); Q = np.asarray(Q, float)",
      "    w = np.linalg.eigvals(np.linalg.solve(P, Q)).real",
      "    w = np.clip(w, 1e-12, None)",
      "    return float(np.sqrt(np.sum(np.log(w) ** 2)))",
      "",
