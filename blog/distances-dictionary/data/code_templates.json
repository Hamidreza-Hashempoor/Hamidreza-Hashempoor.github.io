  "minkowski": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["k >= 1 gives a true metric."],
    "numpy": [
      "import numpy as np",
      "",
      "def minkowski(p, q, k=2):",
      "    d = np.abs(np.asarray(p, float) - np.asarray(q, float))",
      "    return float(np.sum(d ** k) ** (1.0 / k))",
      "",
      "print(minkowski([0, 0], [3, 4], k=3))  # ~4.498"
    ],
    "pytorch": [
      "import torch",
      "",
      "def minkowski(p, q, k=2):",
      "    return torch.sum(torch.abs(p - q) ** k) ** (1.0 / k)"
    ]
  },
