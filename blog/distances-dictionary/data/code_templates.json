  "amari_alpha": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["alpha->+-1 are the KL / reverse-KL limits."],
    "numpy": [
      "import numpy as np",
      "",
      "def amari_alpha(p, q, alpha=0.0, eps=1e-12):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    q = np.asarray(q, float); q = q / q.sum()",
      "    p = np.clip(p, eps, 1.0); q = np.clip(q, eps, 1.0)",
      "    if abs(alpha - 1.0) < 1e-8:",
      "        return float(np.sum(p * np.log(p / q)))",
      "    if abs(alpha + 1.0) < 1e-8:",
      "        return float(np.sum(q * np.log(q / p)))",
      "    c = 4.0 / (1.0 - alpha ** 2)",
      "    aff = np.sum(p ** ((1 - alpha) / 2) * q ** ((1 + alpha) / 2))",
      "    return float(c * (1.0 - aff))",
      "",
      "print(amari_alpha([0.5, 0.5], [0.9, 0.1], alpha=0.0))  # ~0.422"
    ]
  },
