  "sharma_mittal_entropy": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["Handle alpha=1 and beta=1 limits separately."],
    "numpy": [
      "import numpy as np",
      "",
      "def sharma_mittal_entropy(p, alpha=2.0, beta=3.0):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    s = np.sum(p ** alpha)",
      "    return float(1.0 / (1.0 - beta) * (s ** ((1.0 - beta) / (1.0 - alpha)) - 1.0))",
      "",
