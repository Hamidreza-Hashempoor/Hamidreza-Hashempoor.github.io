  "wasserstein": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["1-D closed form for equal-size samples.", "For general cases use scipy.stats.wasserstein_distance or POT (ot.emd2)."],
    "numpy": [
      "import numpy as np",
      "",
      "def wasserstein1_1d(u, v):",
      "    '''1-D Wasserstein-1 (EMD) for equal-size samples.'''",
      "    u = np.sort(np.asarray(u, float))",
      "    v = np.sort(np.asarray(v, float))",
      "    if len(u) != len(v):",
      "        raise ValueError('Equal sizes assumed; else use scipy.stats.wasserstein_distance.')",
      "    return float(np.mean(np.abs(u - v)))",
      "",
      "print(wasserstein1_1d([0, 1, 2, 3], [1, 2, 3, 4]))  # 1.0"
    ],
    "pytorch": [
      "import torch",
      "",
      "def wasserstein1_1d(u, v):",
      "    u, _ = torch.sort(u); v, _ = torch.sort(v)",
      "    return torch.mean(torch.abs(u - v))"
    ]
  },
  "mmd": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["Biased MMD^2 estimate; tune the RBF bandwidth (median heuristic)."],
    "numpy": [
      "import numpy as np",
      "",
      "def _rbf(X, Y, gamma):",
      "    X = np.asarray(X, float).reshape(len(X), -1)",
      "    Y = np.asarray(Y, float).reshape(len(Y), -1)",
      "    sq = ((X[:, None, :] - Y[None, :, :]) ** 2).sum(-1)",
      "    return np.exp(-gamma * sq)",
      "",
      "def mmd2(X, Y, gamma=0.5):",
      "    Kxx = _rbf(X, X, gamma); Kyy = _rbf(Y, Y, gamma); Kxy = _rbf(X, Y, gamma)",
      "    return float(Kxx.mean() + Kyy.mean() - 2.0 * Kxy.mean())",
      "",
      "print(mmd2([0, 1, 2], [3, 4, 5], gamma=0.5))  # ~1.063"
    ],
    "pytorch": [
      "import torch",
      "",
      "def _rbf(X, Y, gamma):",
      "    sq = torch.cdist(X, Y) ** 2",
      "    return torch.exp(-gamma * sq)",
      "",
      "def mmd2(X, Y, gamma=0.5):",
      "    Kxx = _rbf(X, X, gamma); Kyy = _rbf(Y, Y, gamma); Kxy = _rbf(X, Y, gamma)",
      "    return Kxx.mean() + Kyy.mean() - 2.0 * Kxy.mean()"
    ]
  },
  "kolmogorov_smirnov": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["scipy.stats.ks_2samp also returns a p-value."],
    "numpy": [
      "import numpy as np",
      "",
      "def ks_distance(u, v):",
      "    u = np.sort(np.asarray(u, float))",
      "    v = np.sort(np.asarray(v, float))",
      "    grid = np.concatenate([u, v])",
      "    Fu = np.searchsorted(u, grid, side='right') / len(u)",
      "    Fv = np.searchsorted(v, grid, side='right') / len(v)",
      "    return float(np.max(np.abs(Fu - Fv)))",
      "",
      "print(ks_distance([0, 1, 2, 3], [1, 2, 3, 4]))  # 0.25"
    ]
