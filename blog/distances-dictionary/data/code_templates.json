  "levenshtein": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["Classic O(mn) dynamic program; pure Python (no numpy needed)."],
    "numpy": [
      "def levenshtein(a, b):",
      "    n, m = len(a), len(b)",
      "    dp = list(range(m + 1))",
      "    for i in range(1, n + 1):",
      "        prev, dp[0] = dp[0], i",
      "        for j in range(1, m + 1):",
      "            cur = dp[j]",
      "            cost = 0 if a[i - 1] == b[j - 1] else 1",
      "            dp[j] = min(dp[j] + 1, dp[j - 1] + 1, prev + cost)",
      "            prev = cur",
      "    return dp[m]",
      "",
      "print(levenshtein('kitten', 'sitting'))  # 3"
    ]
  },
  "dtw": {
    "requires_probability": false,
    "requires_spd": false,
    "notes": ["Add a Sakoe-Chiba band for speed; DTW is not a metric."],
    "numpy": [
      "import numpy as np",
      "",
      "def dtw(a, b):",
      "    a = np.asarray(a, float); b = np.asarray(b, float)",
      "    n, m = len(a), len(b)",
      "    D = np.full((n + 1, m + 1), np.inf)",
      "    D[0, 0] = 0.0",
      "    for i in range(1, n + 1):",
      "        for j in range(1, m + 1):",
      "            cost = abs(a[i - 1] - b[j - 1])",
      "            D[i, j] = cost + min(D[i - 1, j], D[i, j - 1], D[i - 1, j - 1])",
      "    return float(D[n, m])",
      "",
      "print(dtw([1, 2, 3], [1, 2, 2, 3]))  # 0.0"
    ]
  },
  "kullback_leibler": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["Clip with eps and renormalize.", "Infinite if q=0 where p>0."],
    "numpy": [
      "import numpy as np",
      "",
      "def kl_divergence(p, q, eps=1e-12):",
      "    '''KL(p||q) for probability vectors.'''",
      "    p = np.asarray(p, dtype=float); p = p / p.sum()",
      "    q = np.asarray(q, dtype=float); q = q / q.sum()",
      "    p = np.clip(p, eps, 1.0); q = np.clip(q, eps, 1.0)",
      "    return float(np.sum(p * np.log(p / q)))",
      "",
      "print(kl_divergence([0.5, 0.5], [0.9, 0.1]))  # ~0.511 nats"
    ],
    "pytorch": [
      "import torch",
      "",
      "def kl_divergence(p, q, eps=1e-12):",
      "    p = p / p.sum(); q = q / q.sum()",
      "    p = p.clamp_min(eps); q = q.clamp_min(eps)",
      "    return torch.sum(p * torch.log(p / q))"
    ],
    "jax": [
      "import jax.numpy as jnp",
      "",
      "def kl_divergence(p, q, eps=1e-12):",
      "    p = p / p.sum(); q = q / q.sum()",
      "    p = jnp.clip(p, eps, 1.0); q = jnp.clip(q, eps, 1.0)",
      "    return jnp.sum(p * jnp.log(p / q))"
    ]
  },
  "reverse_kl": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["Just KL with the arguments swapped."],
    "numpy": [
      "import numpy as np",
      "",
      "def reverse_kl(p, q, eps=1e-12):",
      "    '''KL(q||p).'''",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    q = np.asarray(q, float); q = q / q.sum()",
      "    p = np.clip(p, eps, 1.0); q = np.clip(q, eps, 1.0)",
      "    return float(np.sum(q * np.log(q / p)))",
      "",
      "print(reverse_kl([0.5, 0.5], [0.9, 0.1]))  # ~0.368"
    ],
    "pytorch": [
      "import torch",
      "",
      "def reverse_kl(p, q, eps=1e-12):",
      "    p = (p / p.sum()).clamp_min(eps)",
      "    q = (q / q.sum()).clamp_min(eps)",
      "    return torch.sum(q * torch.log(q / p))"
    ]
  },
  "pearson_chi2": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["Sensitive to small p_i; clip the denominator."],
    "numpy": [
      "import numpy as np",
      "",
      "def pearson_chi2(p, q, eps=1e-12):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    q = np.asarray(q, float); q = q / q.sum()",
      "    p = np.clip(p, eps, 1.0)",
      "    return float(np.sum((q - p) ** 2 / p))",
      "",
      "print(pearson_chi2([0.5, 0.5], [0.9, 0.1]))  # 0.64"
    ]
  },
  "neyman_chi2": {
