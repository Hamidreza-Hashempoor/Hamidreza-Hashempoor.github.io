  "renyi_entropy": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["alpha=2 collision entropy; alpha->inf min-entropy."],
    "numpy": [
      "import numpy as np",
      "",
      "def renyi_entropy(p, alpha=2.0, eps=1e-12):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    p = np.clip(p, eps, 1.0)",
      "    if abs(alpha - 1.0) < 1e-8:",
      "        return float(-np.sum(p * np.log(p)))",
      "    return float(1.0 / (1.0 - alpha) * np.log(np.sum(p ** alpha)))",
      "",
      "print(renyi_entropy([0.5, 0.25, 0.25], alpha=2))  # ~0.981 nats"
    ]
  },
  "tsallis_entropy": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["T_2 = 1 - sum p_i^2 (Gini-Simpson index)."],
    "numpy": [
      "import numpy as np",
      "",
      "def tsallis_entropy(p, alpha=2.0):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    return float(1.0 / (1.0 - alpha) * (np.sum(p ** alpha) - 1.0))",
      "",
      "print(tsallis_entropy([0.5, 0.25, 0.25], alpha=2))  # 0.625"
