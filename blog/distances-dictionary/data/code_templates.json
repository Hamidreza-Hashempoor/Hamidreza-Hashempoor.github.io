  "mahalanobis": {
    "requires_probability": false,
    "requires_spd": true,
    "notes": ["Solve against Sigma instead of inverting it."],
    "numpy": [
      "import numpy as np",
      "",
      "def mahalanobis(p, q, Sigma):",
      "    d = np.asarray(p, float) - np.asarray(q, float)",
      "    return float(np.sqrt(d @ np.linalg.solve(np.asarray(Sigma, float), d)))",
      "",
      "Sigma = [[2, 0.5], [0.5, 1]]",
      "print(mahalanobis([2, 1], [0, 0], Sigma))  # ~1.512"
    ],
    "pytorch": [
      "import torch",
      "",
      "def mahalanobis(p, q, Sigma):",
      "    d = (p - q).unsqueeze(-1)",
      "    sol = torch.linalg.solve(Sigma, d)",
      "    return torch.sqrt((d.transpose(-1, -2) @ sol).squeeze())"
    ]
  },
