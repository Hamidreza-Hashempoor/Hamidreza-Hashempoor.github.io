      "",
      "def hausdorff(X, Y):",
      "    X = np.asarray(X, float); Y = np.asarray(Y, float)",
      "    d = np.sqrt(((X[:, None, :] - Y[None, :, :]) ** 2).sum(-1))",
      "    return float(max(d.min(axis=1).max(), d.min(axis=0).max()))",
      "",
      "X = [[0, 0], [1, 0], [0, 1]]; Y = [[0, 0], [1, 1]]",
