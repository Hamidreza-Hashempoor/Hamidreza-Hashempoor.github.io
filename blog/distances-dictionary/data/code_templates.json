  "hellinger": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["Numerically stable (no logs); bounded in [0, 1]."],
    "numpy": [
      "import numpy as np",
      "",
      "def hellinger(p, q):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    q = np.asarray(q, float); q = q / q.sum()",
      "    return float(np.sqrt(0.5 * np.sum((np.sqrt(p) - np.sqrt(q)) ** 2)))",
      "",
      "print(hellinger([0.5, 0.5], [0.9, 0.1]))  # ~0.325"
    ],
    "pytorch": [
