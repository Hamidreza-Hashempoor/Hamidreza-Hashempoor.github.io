  "shannon_entropy": {
    "requires_probability": true,
    "requires_spd": false,
    "notes": ["Use base=2 for bits, base=e for nats."],
    "numpy": [
      "import numpy as np",
      "",
      "def shannon_entropy(p, base=np.e, eps=1e-12):",
      "    p = np.asarray(p, float); p = p / p.sum()",
      "    p = np.clip(p, eps, 1.0)",
      "    return float(-np.sum(p * np.log(p)) / np.log(base))",
      "",
      "print(shannon_entropy([0.5, 0.25, 0.25]))         # ~1.040 nats",
      "print(shannon_entropy([0.5, 0.25, 0.25], base=2)) # 1.5 bits"
    ]
